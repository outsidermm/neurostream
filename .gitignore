# =============================================================================
# NeuroStream .gitignore
# Covers: Python, C++, CUDA, ML tooling (MLflow/Hydra/PyTorch), OS/IDE cruft
# =============================================================================

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
# Never commit datasets or derived artifacts
data/
!data/.gitkeep
datasets/
*.gdf
*.edf
*.bdf
*.fif
*.set
*.vhdr
*.vmrk
*.eeg

# MLflow tracking (self-hosted)
mlruns/
mlflow.db
mlflow.db-journal
mlartifacts/

# Hydra multirun / single-run outputs
outputs/
multirun/
.hydra/

# Model checkpoints & large binaries
*.pt
*.pth
*.ckpt
*.onnx
*.safetensors
*.bin
*.h5
checkpoints/
models/*.pt
models/*.onnx

# Results that are regenerated (commit specific tagged reports manually if needed)
results/
!results/.gitkeep

# Experiment scratch
scratch/
tmp/
wandb/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Translations
*.mo
*.pot

# Jupyter Notebook
.ipynb_checkpoints
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# IPython
profile_default/
ipython_config.py

# pyenv / version managers
.python-version

# pipenv / poetry / pdm (not used, but guard against accidental commits)
Pipfile.lock
poetry.lock
.pdm.toml
.pdm-python
.pdm-build/

# uv — DO commit uv.lock (reproducibility); ignore caches only
.uv-cache/

# Environments
.env
.env.*
!.env.example
.venv
.venv.*
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder / Rope
.spyderproject
.spyproject
.ropeproject

# mkdocs / Sphinx
/site
docs/_build/

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

